# Copy this file to .env and fill in your own values
# Never commit .env — it's in .gitignore

# Mapbox API key — get one free at https://account.mapbox.com
# Used for real drive-time calculations in src/engine/eta.ts
# Without this, ETA falls back to straight-line distance estimates
EXPO_PUBLIC_MAPBOX_KEY=your_mapbox_public_token_here
